rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ── Kullanıcı profilleri ───────────────────────────────────────────
    match /users/{userId} {
      // Herkes okuyabilir (liderboard, profil görüntüleme)
      allow read: if isAuth();
      // Sadece kendi dokümanını yazabilir; teamId alanını herhangi bir
      // giriş yapmış kullanıcı değiştirebilir (admin üye ekleme/silme için)
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
                    || (isAuth() && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['teamId']));
      allow delete: if false;

      // Okuma logları — herkes okuyabilir (liderboard için), sadece sahibi yazabilir
      match /logs/{logId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }

      // Hatimler — sadece sahibi
      match /hatims/{hatimId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Ekipler ────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Herkes okuyabilir
      allow read: if isAuth();
      // Ekip kurma: adminUid kendi uid'i olmalı
      allow create: if isAuth() && request.auth.uid == request.resource.data.adminUid;
      // Güncelleme: herhangi bir giriş yapmış kullanıcı (katılma/ayrılma için)
      allow update: if isAuth();
      // Silme: sadece admin
      allow delete: if isAuth() && request.auth.uid == resource.data.adminUid;

      // Katılma istekleri alt koleksiyonu
      match /requests/{requestId} {
        allow read, write: if isAuth();
      }
    }

    // ── Özellik önerileri ──────────────────────────────────────────────
    match /feature_requests/{requestId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }

    // ── Ekip katılma istekleri ─────────────────────────────────────────
    match /pending_requests/{requestId} {
      allow read, write: if isAuth();
    }
  }
}
