rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDeveloper == true;
    }

    function isDeveloper() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDeveloper == true;
    }

    // ── Kullanıcı profilleri ───────────────────────────────────────────
    match /users/{userId} {
      // Herkes okuyabilir (liderboard, profil görüntüleme)
      allow read: if isAuth();
      allow create: if isOwner(userId);
      // Kendi dokümanı tam erişim; ekip join/leave/kick için teamIds,
      // adminTeamIds, teamJoinedAt alanları diğer auth kullanıcılar tarafından güncellenebilir
      allow update: if isOwner(userId)
                    || (isAuth() && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['teamIds', 'adminTeamIds', 'teamJoinedAt', 'pendingTeamIds']))
                    // Geliştirici: cinsiyet ve streakFreezes alanlarını tüm kullanıcılarda güncelleyebilir
                    || (isDeveloper() && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['cinsiyet', 'streakFreezes']))
                    || (isAdmin() && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['isHafiz']));
      allow delete: if isOwner(userId) || isDeveloper();

      // Okuma logları — herkes okuyabilir (liderboard için), sadece sahibi yazabilir
      match /logs/{logId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }

      // Hatimler — sadece sahibi
      match /hatims/{hatimId} {
        allow read, write: if isOwner(userId);
      }

      // Günlük Namaz Takipleri — sadece sahibi
      match /daily_prayers/{dateStr} {
        allow read, write: if isOwner(userId);
      }

      // Vird tercihleri — sadece sahibi
      match /vird_preferences/{virdId} {
        allow read, write: if isOwner(userId);
      }

      // Bildirimler — okuma/silme/güncelleme sadece sahibine; oluşturma auth kullanıcılara açık
      // (lider, isteği kabul/ret ettiğinde karşı kullanıcının bildirimlerine yazar)
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isAuth();
      }
    }

    // ── Ekipler ────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Herkes okuyabilir
      allow read: if isAuth();
      // Ekip kurma: adminUid kendi uid'i olmalı
      allow create: if isAuth() && request.auth.uid == request.resource.data.adminUid;
      // Güncelleme: admin her şeyi; diğerleri sadece memberCount
      allow update: if isAuth() && (
        request.auth.uid == resource.data.adminUid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
      );
      // Silme: sadece ekip kurucusu
      allow delete: if isAuth() && request.auth.uid == resource.data.adminUid;

      // Katılma istekleri — tüm auth kullanıcılar okuyabilir/yazabilir
      // (admin onay/red, kullanıcı kendi isteğini iptal, ekip silinince toplu silme)
      match /requests/{requestId} {
        allow read, write: if isAuth();
      }

      // Geçmiş sıralamalar — herkes okuyabilir, admin + üyeler yazabilir
      match /history/{historyId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }

    // ── Feedback Klasörleri ────────────────────────────────────────────
    match /feedback_labels/{labelId} {
      allow read, write: if isAuth();
    }

    // ── Developer Backlog ──────────────────────────────────────────────
    match /app_backlog/{itemId} {
      allow read, write: if isAuth();
    }

    // ── Developer Milestones ───────────────────────────────────────────
    match /app_milestones/{milestoneId} {
      allow read, write: if isAuth();
    }

    // ── Özellik önerileri ──────────────────────────────────────────────
    match /feature_requests/{requestId} {
      allow create: if isAuth();
      allow read, update, delete: if isAuth();
    }

    // ── Ekip katılma istekleri ─────────────────────────────────────────
    match /pending_requests/{requestId} {
      allow read, write: if isAuth();
    }

    // ── Yol Haritası ──────────────────────────────────────────────────────────
    // Herkes okuyabilir (published filtrelemesi client-side); sadece admin yazar
    match /roadmap_entries/{entryId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Uygulama meta verileri (migration flag'leri vb.) ─────────────────
    match /app_meta/{docId} {
      allow read: if isDeveloper();
      allow write: if isDeveloper();
    }

    // ── Yayın bildirimleri (admin audit logu) ─────────────────────────────────
    match /app_broadcasts/{broadcastId} {
      allow read: if isDeveloper();
      allow write: if isDeveloper();
    }

    // ── Hafız doğrulama başvuruları ────────────────────────────────────
    // Oluşturma: yalnızca kendi uid'i için (uid = doc key)
    // Okuma/güncelleme: isAuth() — developer panelinin cross-user erişimi için
    match /hafiz_requests/{uid} {
      allow create: if isAuth() && request.auth.uid == uid;
      allow read:   if isAuth();
      // Sadece başvuru sahibi veya admin güncelleyebilir
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;
    }
  }
}
